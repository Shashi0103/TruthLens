# ─── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# ─── Virtual Environments ─────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── Jupyter ──────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Large Model Files (too big for GitHub) ───────────────
models/*.pkl
models/*.pt
models/bert_model/
models/distilbert_model/

# Keep metrics.json (small, important)
!models/metrics.json

# ─── Datasets (large CSVs) ────────────────────────────────
dataset/
*.csv

# ─── Generated Reports ────────────────────────────────────
reports/

# ─── OS & IDE ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# ─── Streamlit ────────────────────────────────────────────
.streamlit/secrets.toml

# ─── Logs & Temp ──────────────────────────────────────────
*.log
*.tmp
*.bak
